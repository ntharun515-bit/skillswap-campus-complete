# =========================================================================
# ⚙️ SkillSwap - Environment Variables Configuration Template
# =========================================================================
# Copy this file to '.env' in your root directory and fill in your values.
# Do NOT commit your actual '.env' file containing real secrets to git!

# -------------------------------------------------------------------------
# 💻 Server Environment & Flask Configuration
# -------------------------------------------------------------------------
FLASK_APP=run.py
FLASK_ENV=development  # Change to 'production' on Google Cloud Run
SECRET_KEY=generate-a-secure-secret-key-32-chars-long
JWT_SECRET_KEY=generate-another-secure-secret-key-for-jwt

# -------------------------------------------------------------------------
# 🗄️ Relational Database Management (SQLAlchemy)
# -------------------------------------------------------------------------
# Set to 'true' to use SQLite file database locally.
# Set to 'false' in production to connect to managed Cloud SQL (MySQL).
USE_SQLITE=true

# Database connection URL (Required if USE_SQLITE is set to 'false')
# Example for GCP Cloud SQL (MySQL Proxy):
# DATABASE_URL=mysql+pymysql://user:password@/database_name?unix_socket=/cloudsql/project_id:region:instance_name
# Example for local MySQL server:
# DATABASE_URL=mysql+pymysql://root:securepassword@localhost:3306/skillswap
DATABASE_URL=sqlite:///database/skillswap.db

# -------------------------------------------------------------------------
# 🚀 AI & Model Frameworks Integration
# -------------------------------------------------------------------------
# Optional: Hugging Face API Token to drive BART Profile Summary generation
# If left blank, the system falls back to automated local template generators
HUGGINGFACE_API_TOKEN=

# -------------------------------------------------------------------------
# 🔒 Security, CORS & Upload Configurations
# -------------------------------------------------------------------------
# Allowed origins for API requests (comma-separated list)
CORS_ORIGINS=http://localhost:5000,http://127.0.0.1:5000,http://localhost:65211

# Max file size allowed for uploads (in bytes) - Default is 16MB
MAX_CONTENT_LENGTH=16777216
UPLOAD_FOLDER=uploads

# Cookie security settings (Highly recommended to set to 'true' in HTTPS production)
SESSION_COOKIE_SECURE=false
